<heartbeat>
  <automation_id>{{AUTOMATION_ID}}</automation_id>
  <current_time_iso>{{NOW_ISO}}</current_time_iso>
  <instructions>
{{AUTOMATION_PROMPT}}
  </instructions>
</heartbeat>

<!--
  配置 (main.js offset 25683):
    heartbeatInterval = 30000   (30秒)
    maxRetries        = 3
    timeout           = 120000  (2分钟)
    shortTimeout      = 60000   (1分钟)
    warningTimeout    = 30000   (30秒)
    globalTimeout     = 600000  (10分钟)

  模型配置:
    defaultModel          = (pn.model)
    defaultReasoningEffort = (pn.reasoningEffort)

  事件路由:
